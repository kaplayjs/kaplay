f 6/2/ 7/3/ 3/4/
# back
f 7/1/ 6/2/ 5/4/
f 5/2/ 8/3/ 7/4/
# top
f 1/1/ 5/2/ 6/4/
f 6/2/ 2/3/ 1/4/
# bottom
f 8/1/ 4/2/ 3/4/
f 3/2/ 7/3/ 8/4/